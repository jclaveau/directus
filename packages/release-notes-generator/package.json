{
  "name": "@directus/release-notes-generator",
  "version": "3.0.0-rc.0",
  "description": "Directus tailored release notes generator for changesets",
  "homepage": "https://directus.com",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/directus/directus.git",
    "directory": "packages/release-notes-generator"
  },
  "funding": "https://github.com/directus/directus?sponsor=1",
  "license": "MIT",
  "author": "Pascal Jufer <pascal-jufer@bluewin.ch>",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@changesets/get-github-info": "0.6.0",
    "@pnpm/logger": "1001.0.1",
    "@pnpm/workspace.find-packages": "1000.0.43",
    "@pnpm/workspace.pkgs-graph": "1000.0.25",
    "semver": "7.7.3"
  },
  "devDependencies": {
    "@changesets/types": "6.1.0",
    "@directus/tsconfig": "4.0.0",
    "@types/node": "22.13.14",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "5.9.3",
    "tsdown": "0.15.11",
    "vitest": "3.2.4"
  },
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.prod.json",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
