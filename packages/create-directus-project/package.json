{
  "name": "create-directus-project",
  "version": "13.0.0-rc.0",
  "description": "A small installer util that will create a directory, add boilerplate folders, and install Directus through npm",
  "keywords": [
    "directus",
    "installer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/directus/directus.git",
    "directory": "packages/create-directus-project"
  },
  "license": "MIT",
  "author": "Rijk van Zanten <rijkvanzanten@me.com>",
  "type": "module",
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "main": "lib/index.js",
  "bin": {
    "cdp": "./lib/index.js",
    "create-directus-project": "./lib/index.js"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.2",
    "execa": "9.6.0",
    "fs-extra": "11.3.2",
    "log-symbols": "7.0.1",
    "ora": "8.2.0",
    "update-check": "1.5.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  }
}