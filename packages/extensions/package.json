{
  "name": "@directus/extensions",
  "version": "3.0.9",
  "description": "Utilities and types for Directus extensions",
  "homepage": "https://directus.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/directus/directus.git",
    "directory": "packages/extensions"
  },
  "funding": "https://github.com/directus/directus?sponsor=1",
  "license": "MIT",
  "author": "Rijk van Zanten <rijkvanzanten@me.com>",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node.js",
    "./package.json": "./package.json",
    "./api.d.ts": "./api.d.ts"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "api.d.ts"
  ],
  "dependencies": {
    "@types/express": "4.17.25",
    "fs-extra": "11.3.5",
    "lodash-es": "4.18.1",
    "zod": "4.4.3",
    "@directus/constants": "13.0.2",
    "@directus/types": "13.2.1",
    "@directus/utils": "13.0.9"
  },
  "devDependencies": {
    "@directus/tsconfig": "4.0.0",
    "@types/fs-extra": "11.0.4",
    "@types/lodash-es": "4.17.12",
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "3.2.6",
    "knex": "3.1.0",
    "pino": "10.3.1",
    "tsdown": "0.15.11",
    "typescript": "5.8.3",
    "vitest": "3.2.6",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "peerDependencies": {
    "knex": "3.1.0",
    "pino": "10.3.1",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "peerDependenciesMeta": {
    "knex": {
      "optional": true
    },
    "pino": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "vue-router": {
      "optional": true
    }
  },
  "scripts": {
    "//build-no-clean": "build:node and build:shared both emit into dist/. When pnpm runs them sequentially (e.g. workspace-concurrency=1), the second tsdown cleans the first's output (index.js/node.js) before writing its own. --no-clean disables that step so both sets of outputs coexist.",
    "build": "pnpm run '/^build:.*/'",
    "build:node": "tsdown src/node.ts --tsconfig src/node/tsconfig.json --out-dir dist --dts --no-clean",
    "build:shared": "tsdown src/index.ts --tsconfig src/tsconfig.json --out-dir dist --dts --no-clean",
    "dev": "pnpm run '/^build:.*/' --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  }
}