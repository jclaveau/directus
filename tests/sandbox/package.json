{
  "name": "@directus/sandbox",
  "version": "0.0.0",
  "description": "Toolkit for spinning up directus test environments",
  "homepage": "https://directus.com",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "bin": {
    "sandbox": "dist/cli.js"
  },
  "files": [
    "dist",
    "docker"
  ],
  "keywords": [],
  "type": "module",
  "author": "Nils Twelker (nils@directus.io)",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@directus/tsconfig": "4.0.0",
    "@types/lodash-es": "4.17.12",
    "@types/node": "22.13.14",
    "chalk": "5.6.2",
    "commander": "14.0.2",
    "copyfiles": "2.4.1",
    "detect-port": "2.1.0",
    "get-port": "7.1.0",
    "knex": "3.1.0",
    "lodash-es": "4.18.1",
    "tsdown": "0.15.11",
    "tsx": "4.20.6",
    "typedoc": "0.28.12",
    "typedoc-plugin-markdown": "4.8.1",
    "typescript": "5.9.3",
    "@directus/types": "16.0.0-rc.1",
    "@directus/utils": "13.5.0-rc.1"
  },
  "engines": {
    "node": ">=22"
  },
  "optionalDependencies": {
    "mysql2": "3.15.3",
    "oracledb": "6.10.0",
    "pg": "8.16.3",
    "sqlite3": "5.1.7",
    "tedious": "18.6.1"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "build": "tsdown src/index.ts src/cli.ts --dts --unbundle && copyfiles src/docker/*.yml dist -u 1",
    "dev": "tsdown -w",
    "build:tests": "tsdown src/index.ts  --format=esm",
    "docs": "typedoc --plugin typedoc-plugin-markdown --out ./docs"
  }
}