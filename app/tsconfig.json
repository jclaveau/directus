{
	"extends": "@directus/tsconfig/vue3",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"verbatimModuleSyntax": false,
		"exactOptionalPropertyTypes": false,
		"noPropertyAccessFromIndexSignature": false,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["env.d.ts", "src/**/*", "src/**/*.vue"]
}
